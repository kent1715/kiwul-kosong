+// Anti-stacking negative prompt untuk scene 2-karakter (Qwen-Image-Edit-2509 / port 9500).
+// Mencegah: wajah menyatu, badan merge, duplikat orang, hantu/bayangan di dinding kosong.
+const ANTI_STACKING_NEGATIVE_PROMPT =
+  'blended faces, merged body, duplicate person, extra people, fused characters, ' +
+  'wrong gender, wrong hairstyle, wrong outfit, swapped identity, ' +
+  'deformed hands, extra limbs, cropped head, blurry face, faceless, ' +
+  'ghost, shadow on wall, silhouette, transparency, blur, low quality'
+
+// Negative prompt default lebih ringan untuk scene 1-karakter (port 9410).
+const SINGLE_CHARACTER_NEGATIVE_PROMPT =
+  'deformed hands, extra limbs, blurry face, faceless, ghost, low quality'
+
+function resolveNegativePrompt(
+  sceneNegative: string | null | undefined,
+  variant: 'two-character' | 'single-character'
+): string {
+  const userNeg = String(sceneNegative || '').trim()
+  const base =
+    variant === 'two-character'
+      ? ANTI_STACKING_NEGATIVE_PROMPT
+      : SINGLE_CHARACTER_NEGATIVE_PROMPT
+  return userNeg ? `${base}, ${userNeg}` : base
+}
